FROM mcr.microsoft.com/playwright/python:v1.45.0-jammy

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .
RUN mkdir -p /config && cp /app/targets.yaml /config/targets.yaml

EXPOSE 8079
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8079", "--log-level", "info"]
