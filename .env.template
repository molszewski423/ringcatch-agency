# ── Lead scraper ─────────────────────────────────────────────────────────────
HUNTER_API_KEY=your_hunter_io_api_key
MAX_LEADS_PER_DAY=75

# ── Email sending ────────────────────────────────────────────────────────────
# "stub"  → log emails to container stdout, never send (development default)
# "brevo" → Brevo transactional API (free tier: 300/day)
# "resend"→ Resend API
EMAIL_PROVIDER=stub

# Fill these in when switching EMAIL_PROVIDER away from "stub"
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_NAME=Alex from RingCatch
BREVO_SENDER_EMAIL=alex@ringcatchai.com
# RESEND_API_KEY=re_your_resend_api_key

# ── Cloudflare ───────────────────────────────────────────────────────────────
# 1. Create an API token at dash.cloudflare.com → My Profile → API Tokens
#    Permissions: Cloudflare Tunnel:Edit  DNS:Edit  Zone:Read
# 2. Set CLOUDFLARE_API_TOKEN and CLOUDFLARE_ZONE_ID below
# 3. Run:  bash ~/agency/scripts/tunnel-setup.sh
#    This creates the tunnel, sets DNS, and writes CLOUDFLARE_TUNNEL_TOKEN here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=5fa18274dc370ccb5b4494fbecef2814
# Auto-populated by tunnel-setup.sh — do not edit manually
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://host.containers.internal:11434
# Customer-facing chat (fast, low latency)
CHAT_MODEL=qwen2.5:7b
# Backend tasks: email generation, document creation, lead personalization
