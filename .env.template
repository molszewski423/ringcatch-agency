# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=agency
POSTGRES_PASSWORD=changeme
POSTGRES_DB=calcom
DATABASE_URL=postgresql://agency:changeme@localhost:5432/calcom

# ── n8n ─────────────────────────────────────────────────────────────────────
